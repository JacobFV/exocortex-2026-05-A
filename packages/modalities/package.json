{
  "name": "@exocortex/modalities",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mobile": {
      "types": "./dist/mobile.d.ts",
      "default": "./dist/mobile.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx src/head-bridge-registry.test.ts"
  },
  "dependencies": {
    "@exocortex/calibration": "0.0.0",
    "@exocortex/hardware": "0.0.0",
    "@exocortex/protocol": "0.0.0",
    "@exocortex/transports": "0.0.0"
  }
}
