{
  "name": "@exocortex/session",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mobile": {
      "types": "./dist/mobile.d.ts",
      "default": "./dist/mobile.js"
    },
    "./sqlite": {
      "types": "./dist/sqlite-agent-session-store.d.ts",
      "default": "./dist/sqlite-agent-session-store.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build -w @exocortex/protocol && tsx src/session-manager.test.ts && tsx src/sqlite-agent-session-store.test.ts"
  },
  "dependencies": {
    "@exocortex/browser-session": "0.0.0",
    "@exocortex/continuity": "0.0.0",
    "@exocortex/models": "0.0.0",
    "@exocortex/modalities": "0.0.0",
    "@exocortex/protocol": "0.0.0"
  }
}
