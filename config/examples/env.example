# Copy to config/local/.env and fill in local-only values.
# Do not commit config/local/.env.

# Hosted model and media providers.
OPENAI_API_KEY=
EXOCORTEX_OPENAI_MODEL=gpt-4o-mini
EXOCORTEX_OPENAI_BASE_URL=https://api.openai.com/v1

# Optional local model providers.
EXOCORTEX_OLLAMA_MODEL=llama3.2
# EXOCORTEX_LLAMA_CPP_COMMAND=/path/to/llama-cli
# EXOCORTEX_LLAMA_CPP_ARGS=["-m","/path/to/model.gguf","-p"]

# Optional head bridge serial device.
# EXOCORTEX_HEAD_BRIDGE_SERIAL=/dev/ttyUSB0
EXOCORTEX_HEAD_BRIDGE_BAUD=115200
EXOCORTEX_HEAD_BRIDGE_RECONNECT=true
EXOCORTEX_HEAD_BRIDGE_MAX_WRITE_QUEUE=64

# Optional local media capture command templates.
# EXOCORTEX_IMAGE_CAPTURE_COMMAND=
# EXOCORTEX_IMAGE_CAPTURE_ARGS=["{output}"]
# EXOCORTEX_AUDIO_CAPTURE_COMMAND=
# EXOCORTEX_AUDIO_CAPTURE_ARGS=["{output}"]
# EXOCORTEX_VIDEO_CAPTURE_COMMAND=
# EXOCORTEX_VIDEO_CAPTURE_ARGS=["{output}","{durationSeconds}","{deviceId}"]

# Optional continuous Electron STT bridge from configured audio capture into text modalities.
EXOCORTEX_STT_BRIDGE_ENABLED=0
EXOCORTEX_STT_BRIDGE_INTERVAL_MS=5000
EXOCORTEX_STT_BRIDGE_CAPTURE_MS=2500
# EXOCORTEX_STT_BRIDGE_PROVIDER=openai-stt

# Optional durable local paths.
# EXOCORTEX_EVENT_GRAPH_DB=/absolute/path/continuity-events.db
# EXOCORTEX_AGENT_SESSION_DB=/absolute/path/agent-sessions.db
# EXOCORTEX_ARTIFACT_BLOB_DIR=/absolute/path/artifact-blobs
