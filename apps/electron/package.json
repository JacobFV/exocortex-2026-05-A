{
  "name": "@exocortex/electron",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx src/renderer-html.test.ts",
    "dev": "npm run build -w @exocortex/continuity && npm run build -w @exocortex/session && npm run build && electron dist/main.js",
    "dev:no-sandbox": "npm run build -w @exocortex/continuity && npm run build -w @exocortex/session && npm run build && electron --no-sandbox dist/main.js"
  },
  "dependencies": {
    "@exocortex/browser-session": "0.0.0",
    "@exocortex/calibration": "0.0.0",
    "@exocortex/continuity": "0.0.0",
    "@exocortex/hardware": "0.0.0",
    "@exocortex/media": "0.0.0",
    "@exocortex/models": "0.0.0",
    "@exocortex/modalities": "0.0.0",
    "@exocortex/protocol": "0.0.0",
    "@exocortex/safety": "0.0.0",
    "@exocortex/session": "0.0.0",
    "@exocortex/transports": "0.0.0",
    "@types/react": "^19.2.6",
    "electron": "^42.2.0",
    "expo": "^55.0.25",
    "react": "^19.2.6",
    "react-native": "^0.85.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.12"
  }
}
